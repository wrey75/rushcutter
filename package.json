{
  "name": "rushcutter",
  "version": "1.0.0",
  "description": "Logiciel de dérushing vidéo professionnel",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.rushcutter.app",
    "productName": "RushCutter",
    "directories": {
      "output": "dist"
    },
    "files": ["src/**/*", "assets/**/*"],
    "mac": {
      "category": "public.app-category.video",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.2",
    "ffprobe-static": "^3.1.0",
    "ffmpeg-static": "^5.2.0"
  }
}
